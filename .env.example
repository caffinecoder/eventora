# ── Eventora Backend Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values. Never commit .env to git.

# Django
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database
DB_NAME=eventora_db
DB_USER=root
DB_PASSWORD=Sharmista@123
DB_HOST=127.0.0.1
DB_PORT=3306

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS — frontend origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
